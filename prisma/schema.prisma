// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // IMPORTANT: You must provide the database connection URL via an environment variable.
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. ROLES & ACCESS CONTROL (RBAC)
// ==========================================

enum RoleType {
  SUPER_ADMIN
  BRANCH_MANAGER
  PHARMACIST
  CASHIER
  SUPPLIER
  DELIVERY_RIDER
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  role          RoleType  @default(CASHIER)
  isActive      Boolean   @default(true)
  
  // A user can be assigned to a specific branch (except Super Admin / Delivery Float)
  branchId      String?   @db.Uuid
  branch        Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  
  sales         Sale[]    // Track which user made which sales
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([branchId])
}

// ==========================================
// 2. MULTI-BRANCH MANAGEMENT
// ==========================================

model Branch {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String    
  code          String    @unique // e.g., BR-DHK-01
  address       String
  contactEmail  String?
  contactPhone  String?
  isActive      Boolean   @default(true)
  
  users         User[]
  inventories   Inventory[]
  sales         Sale[]
  stockTransfersFrom StockTransfer[] @relation("TransferSource")
  stockTransfersTo   StockTransfer[] @relation("TransferDestination")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ==========================================
// 3. MASTER CATALOG & INVENTORY
// ==========================================

// Master catalog shared across all branches (No stock data here)
model Product {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku             String    @unique
  barcode         String?   @unique
  name            String
  genericName     String?
  category        String
  manufacturer    String?
  description     String?
  
  // Base pricing (Can be overridden at branch level if needed)
  mrp             Decimal   @db.Decimal(10, 2)
  isNarcotic      Boolean   @default(false)
  
  inventories     Inventory[]
  batches         Batch[]
  sales           Sale[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([name])
  @@index([barcode])
  @@map("medicines")
}

// Branch-specific inventory tracker
model Inventory {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId        String    @db.Uuid
  productId       String    @db.Uuid
  
  totalStock      Int       @default(0)
  reorderLevel    Int       @default(20) // When to trigger PO alert
  
  branch          Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product         Product   @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  
  inventoryBatches InventoryBatch[]

  updatedAt       DateTime  @updatedAt

  @@unique([branchId, productId]) // One product inventory record per branch
}

// Master Batches (Received from Manufacturer)
model Batch {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String    @db.Uuid
  batchNumber     String
  manufactureDate DateTime?
  expiryDate      DateTime
  
  purchasePrice   Decimal   @db.Decimal(10, 2)
  
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  inventoryBatches InventoryBatch[] 
  
  createdAt       DateTime  @default(now())

  @@unique([productId, batchNumber])
  @@index([expiryDate]) // Crucial for FEFO logic
}

// How much of a specific batch is sitting in a specific branch
model InventoryBatch {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inventoryId     String    @db.Uuid
  batchId         String    @db.Uuid
  
  quantity        Int       @default(0) // Available quantity of THIS batch in THIS branch
  
  inventory       Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  batch           Batch     @relation(fields: [batchId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([inventoryId, batchId])
}

// ==========================================
// 4. STOCK TRANSFERS & POS (Skeletons)
// ==========================================

model StockTransfer {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fromBranchId    String    @db.Uuid
  toBranchId      String    @db.Uuid
  status          TransferStatus @default(PENDING)
  
  fromBranch      Branch    @relation("TransferSource", fields: [fromBranchId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  toBranch        Branch    @relation("TransferDestination", fields: [toBranchId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  
  createdAt       DateTime  @default(now())
}

model Sale {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId        String?   @db.Uuid
  userId          String    @db.Uuid
  medicineId      String    @db.Uuid
  quantity        Int
  totalAmount     Decimal   @db.Decimal(10, 2) @map("total_price")
  customerName    String?   @default("Walk-in Customer") @map("customer_name")
  
  branch          Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  product         Product   @relation(fields: [medicineId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  
  createdAt       DateTime  @default(now())

  @@map("sales")
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  REJECTED
}

// ==========================================
// 5. SUBSCRIPTION & BILLING MANAGEMENT
// ==========================================

enum SubscriptionStatus {
  TRIAL        // Free 1-month trial period
  ACTIVE       // Paid subscription is active
  PAUSED       // Temporarily paused by user
  CANCELLED    // User cancelled subscription
  EXPIRED      // Trial/subscription period expired
  PENDING_PAYMENT  // Payment pending
}

enum SubscriptionPlan {
  STARTER      // 1000 BDT/month
}

model Subscription {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String    @unique @db.Uuid
  plan                  SubscriptionPlan @default(STARTER)
  status                SubscriptionStatus @default(TRIAL)
  
  // Trial period
  trialStartDate        DateTime  @default(now())
  trialEndDate          DateTime  // 30 days from signup
  
  // Paid subscription
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  
  // Renewal tracking
  nextBillingDate       DateTime?
  lastBillingDate       DateTime?
  
  // Payment info
  paymentMethod         String?   // SSLCOMMERZ, CARD, etc.
  sslCommerzCustomerId  String?   // For recurring payments
  
  // Auto-renewal settings
  autoRenew             Boolean   @default(true)
  
  // Contact info for billing
  companyName           String?
  billingEmail          String?
  billingPhone          String?
  billingAddress        String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  invoices              Invoice[]
  payments              Payment[]
}

model Invoice {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId        String    @db.Uuid
  invoiceNumber         String    @unique // INV-2026-0001
  
  amount                Decimal   @db.Decimal(10, 2)  // 1000.00 BDT per month
  currency              String    @default("BDT")
  
  billingPeriodStart    DateTime
  billingPeriodEnd      DateTime
  dueDate               DateTime
  
  status                String    @default("UNPAID")  // UNPAID, PAID, OVERDUE, CANCELLED
  paidDate              DateTime?
  
  description           String    // "MediStore Lite - Subscription (Month of April 2026)"
  
  subscription          Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payments              Payment[]
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
}

model Payment {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId        String    @db.Uuid
  invoiceId             String?   @db.Uuid
  
  referenceId           String?   @unique  // SSLCommerz transaction ID
  amount                Decimal   @db.Decimal(10, 2)
  currency              String    @default("BDT")
  
  paymentMethod         String    // SSLCOMMERZ, MANUAL, etc.
  status                String    @default("PENDING")  // PENDING, SUCCESS, FAILED, REFUNDED
  
  paymentGatewayResponse String?  // JSON response from gateway
  
  subscription          Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoice               Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@index([subscriptionId])
  @@index([status])
  @@index([referenceId])
}
